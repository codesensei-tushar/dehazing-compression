#!/bin/bash
# Connect to the GPU cluster. Credentials come from project-local .env.
# Usage:
#   ./gpu              # interactive shell
#   ./gpu "<command>"  # run a one-off remote command

set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$PROJECT_DIR/.env"

if [ ! -f "$ENV_FILE" ]; then
    echo "Missing $ENV_FILE — create it from .env.example" >&2
    exit 1
fi

set -a
# Parse only KEY=VALUE lines so comments / free-form text in .env are safe.
eval "$(grep -E '^[A-Za-z_][A-Za-z0-9_]*=' "$ENV_FILE")"
set +a

: "${CLUSTER_USER:?CLUSTER_USER not set in .env}"
: "${CLUSTER_HOST:?CLUSTER_HOST not set in .env}"
: "${CLUSTER_PASSWORD:?CLUSTER_PASSWORD not set in .env}"

if ! command -v sshpass &> /dev/null; then
    echo "Error: 'sshpass' is not installed." >&2
    echo "  Ubuntu/Debian: sudo apt install sshpass" >&2
    exit 1
fi

if [ "$#" -eq 0 ]; then
    echo "Connecting to $CLUSTER_USER@$CLUSTER_HOST..."
    sshpass -p "$CLUSTER_PASSWORD" ssh -o StrictHostKeyChecking=accept-new \
        "$CLUSTER_USER@$CLUSTER_HOST"
else
    sshpass -p "$CLUSTER_PASSWORD" ssh -o StrictHostKeyChecking=accept-new \
        "$CLUSTER_USER@$CLUSTER_HOST" "$@"
fi
